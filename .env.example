# Resend Configuration (email reports)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Verified sender address (defaults to onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=JobProof <reports@yourdomain.com>

# what3words Configuration (location evidence)
W3W_API_KEY=your_w3w_api_key_here

# Mailchimp Configuration (optional - landing page subscribe)
# Get your API key from https://mailchimp.com/account/api/
MAILCHIMP_API_KEY=your_api_key_here
MAILCHIMP_AUDIENCE_ID=your_audience_id_here
MAILCHIMP_SERVER_PREFIX=us1

# Stripe Configuration (for future payments)
# Get your keys from https://stripe.com/dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
